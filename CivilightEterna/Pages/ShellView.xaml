<Window x:Class="CivilightEterna.Pages.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CivilightEterna.Pages"
        mc:Ignorable="d"
        Title="Civilight Eterna " Height="500" Width="800"
        MinHeight="500" MinWidth="800"
        xmlns:s="https://github.com/canton7/Stylet"
        d:DataContext="{d:DesignInstance local:ShellViewModel}"
        xmlns:uiw="http://schemas.inkore.net/lib/ui/wpf"
        xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern" FontFamily="{DynamicResource MiSans}"
        WindowStartupLocation="CenterScreen"
        FontSize="14" TextOptions.TextRenderingMode="Auto" TextOptions.TextHintingMode="Animated" TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True" FontWeight="Regular"
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ItemsControl Background="{DynamicResource {x:Static SystemColors.ControlLightLightBrushKey}}" Grid.Row="1" BorderThickness="0" ItemsSource="{Binding MainConductor.Items}" BorderBrush="{x:Null}">
            <ItemsControl.Effect>
                <DropShadowEffect Direction="0" ShadowDepth="0" BlurRadius="16" Opacity="0.2"/>
            </ItemsControl.Effect>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="1" Margin="5,5,5,5" VerticalAlignment="Top"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button ui:ElevationBorder.IsElevationEnabled="False" Padding="8,0" ui:ControlHelper.CornerRadius="21" Height="42" BorderThickness="1.2" Foreground="{Binding IsActive, Converter={StaticResource AbleStatusBrushConverter}}" Background="Transparent" Margin="20,8,8,8" Command="{s:Action Switch}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" CommandParameter="{Binding}">
                        <FrameworkElement.Resources>
                            <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPointerOverKey}" Color="Transparent"/>
                            <LinearGradientBrush x:Key="{x:Static ui:ThemeKeys.ButtonBackgroundPressedKey}" EndPoint="0.8,0.8" StartPoint="0,0.5" SpreadMethod="Pad">
                                <GradientStop Color="#99FFC107"/>
                                <GradientStop Color="#00FFC107" Offset="1"/>
                            </LinearGradientBrush>
                            <SolidColorBrush x:Key="{x:Static ui:ThemeKeys.ButtonBorderBrushKey}" Color="Transparent"/>
                            <LinearGradientBrush x:Key="{x:Static ui:ThemeKeys.ButtonBorderBrushPointerOverKey}" EndPoint="0.8,0.8" StartPoint="0,0.5" SpreadMethod="Pad">
                                <GradientStop Color="{StaticResource MAINDARKO9}"/>
                                <GradientStop Color="{StaticResource MAINDARKO0}" Offset="1"/>
                            </LinearGradientBrush>
                            <LinearGradientBrush x:Key="{x:Static ui:ThemeKeys.ButtonBorderBrushPressedKey}" EndPoint="0.8,0.8" StartPoint="0,0.5" SpreadMethod="Pad">
                                <GradientStop Color="#FFFFC107"/>
                                <GradientStop Color="#00FFC107" Offset="1"/>
                            </LinearGradientBrush>
                        </FrameworkElement.Resources>
                        <Grid>
                            <TextBlock FontFamily="{StaticResource FluentIcon}" HorizontalAlignment="Left" FontSize="20" Margin="5,0,0,0" VerticalAlignment="Center" Text="{Binding DisplayName, Converter={StaticResource StringSplitbySpaceConverter}, ConverterParameter=0}" />
                            <TextBlock FontSize="16" Margin="34,0,0,0" VerticalAlignment="Center"  FontWeight="Bold" Text="{Binding DisplayName, Converter={StaticResource StringSplitbySpaceConverter}, ConverterParameter=2}"/>
                            <TextBlock Text="&#xedda;" FontFamily="{StaticResource FluentIcon}" FontSize="16" Margin="-28,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="{Binding IsActive, Converter={StaticResource BoolToVisiCollaConverter}}" >
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard Storyboard="{StaticResource LeftRightCycle}"/>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                                <TextBlock.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform/>
                                    </TransformGroup>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ContentControl Grid.Column="1" Margin="0,0,0,0" IsTabStop="False" s:View.Model="{Binding MainConductor.ActiveItem}">
        </ContentControl>
    </Grid>
</Window>
